{
    "paths": {
      "/academic-year/{academicYearId}/classes": {
        "post": {
          "tags": ["Academic Year Classes"],
          "summary": "Setup classes for academic year",
          "description": "Configure which classes are available for a specific academic year",
          "parameters": [
            {
              "name": "academicYearId",
              "in": "path",
              "required": true,
              "description": "Academic year ID or label (e.g., '2025' or '2024-2025')",
              "schema": {
                "type": "string",
                "example": "2025"
              }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["selected_classes"],
                  "properties": {
                    "selected_classes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["class_id"],
                        "properties": {
                          "class_id": {
                            "type": "string",
                            "format": "uuid",
                            "description": "ID of the class master",
                            "example": "123e4567-e89b-12d3-a456-426614174000"
                          }
                        }
                      },
                      "example": [
                        {"class_id": "123e4567-e89b-12d3-a456-426614174000"},
                        {"class_id": "123e4567-e89b-12d3-a456-426614174001"},
                        {"class_id": "123e4567-e89b-12d3-a456-426614174002"}
                      ]
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Classes setup successfully for academic year",
              "content": {
                "application/json": {
                  "example": {
                    "statusCode": 201,
                    "data": [
                      {
                        "id": "academic-year-class-uuid-1",
                        "academic_year_id": "2025-academic-year-uuid",
                        "class_master_id": "class-uuid-1",
                        "created_by": "user-uuid",
                        "updated_by": "user-uuid",
                        "createdAt": "2024-01-01T00:00:00.000Z",
                        "updatedAt": "2024-01-01T00:00:00.000Z"
                      }
                    ],
                    "message": "Classes setup successfully for academic year 2025"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request - validation error"
            },
            "404": {
              "description": "Academic year not found"
            }
          }
        },
        "get": {
          "tags": ["Academic Year Classes"],
          "summary": "Get classes for academic year",
          "description": "Retrieve all classes configured for a specific academic year with full class details",
          "parameters": [
            {
              "name": "academicYearId",
              "in": "path",
              "required": true,
              "description": "Academic year ID or label (e.g., '2025' or '2024-2025')",
              "schema": {
                "type": "string",
                "example": "2025"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Academic year classes fetched successfully",
              "content": {
                "application/json": {
                  "example": {
                    "statusCode": 200,
                    "data": [
                      {
                        "id": "academic-year-class-uuid-1",
                        "academic_year_id": "2025-academic-year-uuid",
                        "class_master_id": "class-uuid-1",
                        "classMaster": {
                          "id": "class-uuid-1",
                          "class_name": "Nursery",
                          "class_code": "NUR",
                          "description": "Nursery Class",
                          "display_order": 1
                        }
                      }
                    ],
                    "message": "Academic year classes fetched successfully"
                  }
                }
              }
            },
            "404": {
              "description": "Academic year not found"
            }
          }
        },
        "put": {
          "tags": ["Academic Year Classes"],
          "summary": "Update classes for academic year",
          "description": "Replace all classes for a specific academic year",
          "parameters": [
            {
              "name": "academicYearId",
              "in": "path",
              "required": true,
              "description": "Academic year ID or label (e.g., '2025' or '2024-2025')",
              "schema": {
                "type": "string",
                "example": "2025"
              }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["selected_classes"],
                  "properties": {
                    "selected_classes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["class_id"],
                        "properties": {
                          "class_id": {
                            "type": "string",
                            "format": "uuid",
                            "description": "ID of the class master",
                            "example": "123e4567-e89b-12d3-a456-426614174000"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Classes updated successfully for academic year",
              "content": {
                "application/json": {
                  "example": {
                    "statusCode": 200,
                    "data": [
                      {
                        "id": "academic-year-class-uuid-1",
                        "academic_year_id": "2025-academic-year-uuid",
                        "class_master_id": "class-uuid-1",
                        "created_by": "user-uuid",
                        "updated_by": "user-uuid",
                        "createdAt": "2024-01-01T00:00:00.000Z",
                        "updatedAt": "2024-01-01T00:00:00.000Z"
                      }
                    ],
                    "message": "Classes updated successfully for academic year 2025"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request - validation error"
            },
            "404": {
              "description": "Academic year not found"
            }
          }
        },
        "delete": {
          "tags": ["Academic Year Classes"],
          "summary": "Delete all classes from academic year",
          "description": "Remove all classes from a specific academic year",
          "parameters": [
            {
              "name": "academicYearId",
              "in": "path",
              "required": true,
              "description": "Academic year ID or label (e.g., '2025' or '2024-2025')",
              "schema": {
                "type": "string",
                "example": "2025"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "All classes deleted successfully from academic year",
              "content": {
                "application/json": {
                  "example": {
                    "statusCode": 200,
                    "data": null,
                    "message": "All classes deleted successfully from academic year 2025"
                  }
                }
              }
            },
            "404": {
              "description": "Academic year not found"
            }
          }
        }
      },
      "/academic-year/{academicYearId}/classes/{classId}": {
        "delete": {
          "tags": ["Academic Year Classes"],
          "summary": "Delete specific class from academic year",
          "description": "Remove a specific class from academic year",
          "parameters": [
            {
              "name": "academicYearId",
              "in": "path",
              "required": true,
              "description": "Academic year ID or label (e.g., '2025' or '2024-2025')",
              "schema": {
                "type": "string",
                "example": "2025"
              }
            },
            {
              "name": "classId",
              "in": "path",
              "required": true,
              "description": "Class ID to delete from academic year",
              "schema": {
                "type": "string",
                "format": "uuid",
                "example": "123e4567-e89b-12d3-a456-426614174000"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Class deleted successfully from academic year",
              "content": {
                "application/json": {
                  "example": {
                    "statusCode": 200,
                    "data": null,
                    "message": "Class deleted successfully from academic year 2025"
                  }
                }
              }
            },
            "404": {
              "description": "Academic year or class not found"
            }
          }
        }
      },
      "/academic-year/{academicYearId}/classes/available": {
        "get": {
          "tags": ["Academic Year Classes"],
          "summary": "Get available classes with selection status",
          "description": "Get all available classes with their selection status for the academic year",
          "parameters": [
            {
              "name": "academicYearId",
              "in": "path",
              "required": true,
              "description": "Academic year ID or label (e.g., '2025' or '2024-2025')",
              "schema": {
                "type": "string",
                "example": "2025"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Available classes with selection status fetched successfully",
              "content": {
                "application/json": {
                  "example": {
                    "statusCode": 200,
                    "data": [
                      {
                        "id": "class-uuid-1",
                        "class_name": "Nursery",
                        "class_code": "NUR",
                        "description": "Nursery Class",
                        "display_order": 1,
                        "is_selected": true
                      },
                      {
                        "id": "class-uuid-2",
                        "class_name": "LKG",
                        "class_code": "LKG",
                        "description": "Lower Kindergarten",
                        "display_order": 2,
                        "is_selected": false
                      }
                    ],
                    "message": "Available classes fetched successfully"
                  }
                }
              }
            },
            "404": {
              "description": "Academic year not found"
            }
          }
        }
      }
    },
    "tags": [
      {
        "name": "Academic Year Classes",
        "description": "Academic Year Classes configuration and management"
      }
    ],
    "components": {
      "schemas": {
        "AcademicYearClasses": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "description": "Unique identifier for the academic year class"
            },
            "academic_year_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the academic year"
            },
            "class_master_id": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the class master"
            },
            "created_by": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the user who created this record"
            },
            "updated_by": {
              "type": "string",
              "format": "uuid",
              "description": "ID of the user who last updated this record"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time",
              "description": "Creation timestamp"
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time",
              "description": "Last update timestamp"
            }
          }
        }
      }
    }
  }