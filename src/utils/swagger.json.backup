{
  "openapi": "3.0.0",
  "info": {
    "title": "School-ERP APIs",
    "version": "1.0.0",
    "description": "Comprehensive School Management System API with multi-tenant architecture"
  },
  "tags": [
    {
      "name": "SuperAdmin",
      "description": "Super Admin management operations"
    },
    {
      "name": "Module",
      "description": "Module management for system features"
    },
    {
      "name": "Plan",
      "description": "Subscription plan management"
    },
    {
      "name": "School",
      "description": "School registration and management"
    },
    {
      "name": "Academic Year Settings",
      "description": "Academic year management and configuration"
    },
    {
      "name": "Class Master",
      "description": "Class master data management (Pre-K to 12th grade)"
    },
    {
      "name": "Section Master",
      "description": "Section master data management (A, B, C, D, etc.)"
    },
    {
      "name": "Subject Master",
      "description": "Subject master data management (Academic, Co-curricular, etc.)"
    },
    {
      "name": "House Master",
      "description": "School house master data management (Red, Blue, Green, etc.)"
    },
    {
      "name": "Department Master",
      "description": "Department master data management (Mathematics, Science, etc.)"
    },
    {
      "name": "Leave Type Master",
      "description": "Leave type master data management (Medical, Casual, etc.)"
    },
    {
      "name": "Leave Policy Master",
      "description": "Leave policy master data management (Department-wise leave policies)"
    }
  ],
  "paths":{
    
"/admin/register": {
  "post": {
    "summary": "Create a super admin user",
    "tags": ["SuperAdmin"],
    "requestBody": {
      "required": true,
      "content": {
        "multipart/form-data": {
          "schema": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "example": "admin@example.com"
              },
              "fullName": {
                "type": "string",
                "example": "John Doe"
              },
              "mobileNumber": {
                "type": "string",
                "example": "+919876543210"
              },
              "password": {
                "type": "string",
                "example": "securePassword123"
              },
              "role": {
                "type": "string",
                "example": "super-admin"
              },
              "rolePermission": {
                "type": "string",
                "example": "all"
              },
              "status": {
                "type": "boolean",
                "example": "true"
              },
              "notes": {
                "type": "string",
                "example": "This is the main super admin."
              },
              "adminImage": {
                "type": "string",
                "format": "binary"
              }
            },
            "required": [
              "email",
              "fullName",
              "mobileNumber",
              "password",
              "role",
              "rolePermission",
              "status",
              "notes"
            ]
          }
        }
      }
    },
    "responses": {
      "201": {
        "description": "Super admin created successfully",
        "content": {
          "application/json": {
            "example": {
              "statusCode": 201,
              "data": {
                "user": {
                  "email": "admin@example.com",
                  "role": "super-admin"
                },
                "admin": {
                  "email": "admin@example.com",
                  "fullName": "John Doe",
                  "mobileNumber": "+919876543210",
                  "role": "super-admin",
                  "rolePermission": "all",
                  "status": "active",
                  "notes": "This is the main super admin.",
                  "adminImage": "http://localhost:5000/uploads/admin/profile.jpg"
                }
              },
              "message": "Admin created successfully"
            }
          }
        }
      },
      "400": {
        "description": "Missing required fields"
      },
      "500": {
        "description": "Server error during admin creation"
      }
    }
  }
},

"/admin/login": {
  "post": {
    "summary": "Login as a super admin",
    "tags": ["SuperAdmin"],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "email": {
                "type": "string",
                "example": "admin@example.com"
              },
              "password": {
                "type": "string",
                "example": "securePassword123"
              },
              "role":{
                "type":"string",
                "example":"super-admin,technical-admin..."
              }
            },
            "required": ["email", "password"]
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "User logged in successfully",
        "content": {
          "application/json": {
            "example": {
              "statusCode": 200,
              "data": {
                "user": {"email": "admin@example.com"},
                "accessToken": "jwt_access_token",
                "refreshToken": "jwt_refresh_token"
              },
              "message": "User logged in successfully"
            }
          }
        }
      },
      "404": {
        "description": "Invalid credentials or admin not found"
      }
    }
  }
},

"/admin/filter": {
  "get": {
    "summary": "Filter and search SuperAdmins",
    "tags": ["SuperAdmin"],
    "parameters": [
      {
        "name": "search",
        "in": "query",
        "required": true,
        "description": "Search by fullName (minimum 3 characters required)",
        "schema": {
          "type": "string",
          "example": "John"
        }
      },
      {
        "name": "status",
        "in": "query",
        "required": false,
        "description": "Filter by status: 'active' or 'inactive'",
        "schema": {
          "type": "string",
          "enum": ["active", "inactive"]
        }
      },
      {
        "name": "page",
        "in": "query",
        "required": false,
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "default": 1,
          "example": 1
        }
      },
      {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Number of records per page",
        "schema": {
          "type": "integer",
          "default": 10,
          "example": 10
        }
      }
    ],
    "responses": {
      "200": {
        "description": "Filtered SuperAdmins fetched successfully",
        "content": {
          "application/json": {
            "example": {
              "statusCode": 200,
              "data": {
                "stats": {
                  "totalUsers": 50,
                  "activeUsers": 30,
                  "inactiveUsers": 20
                },
                "pagination": {
                  "totalRecords": 5,
                  "currentPage": 1,
                  "totalPages": 1
                },
                "data": [
                  {
                    "id": "c8e5a7c0-6f27-4e94-8a10-80fd5dc4b4e2",
                    "fullName": "John Doe",
                    "email": "john@example.com",
                    "mobileNumber": "9876543210",
                    "role": "super-admin",
                    "rolePermission": "all",
                    "status": true,
                    "notes": "Main Super Admin",
                    "adminImage": "http://localhost:5000/uploads/admin/john.jpg",
                    "createdAt": "2025-08-13T10:20:30.000Z",
                    "updatedAt": "2025-08-13T10:20:30.000Z"
                  }
                ]
              },
              "message": "Filtered SuperAdmins fetched successfully"
            }
          }
        }
      },
      "400": {
        "description": "Bad request or invalid search parameter"
      }
    }
  }
},

"/admin/delete/{id}": {
  "delete": {
    "summary": "Delete a SuperAdmin",
    "tags": ["SuperAdmin"],
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "UUID of the SuperAdmin to delete",
        "schema": {
          "type": "string",
          "example": "c8e5a7c0-6f27-4e94-8a10-80fd5dc4b4e2"
        }
      }
    ],
    "responses": {
      "200": {
        "description": "SuperAdmin deleted successfully",
        "content": {
          "application/json": {
            "example": {
              "statusCode": 200,
              "data": {},
              "message": "SuperAdmin deleted successfully"
            }
          }
        }
      },
      "404": {
        "description": "SuperAdmin not found"
      },
      "500": {
        "description": "Server error during deletion"
      }
    }
  }
},

"/admin/schools": {
  "get": {
    "summary": "Get all schools with associated plans",
    "tags": ["SuperAdmin"],
    "responses": {
      "200": {
        "description": "Schools retrieved successfully",
        "content": {
          "application/json": {
            "example": {
              "message": "Schools retrieved successfully",
              "data": [
                {
                  "id": 1,
                  "name": "School A",
                  "plans": [
                    {"planId": 101, "name": "Basic"},
                    {"planId": 102, "name": "Premium"}
                  ]
                }
              ]
            }
          }
        }
      }
    }
  }
},

"/admin/current-user": {
  "get": {
    "summary": "Get currently logged-in user",
    "tags": ["SuperAdmin"],
    "responses": {
      "200": {
        "description": "User fetched successfully",
        "content": {
          "application/json": {
            "example": {
              "statusCode": 200,
              "data": {
                "id": "user123",
                "email": "user@example.com",
                "role": "super-admin"
              },
              "message": "User fetched successfully"
            }
          }
        }
      }
    }
  }
},

"/admin/logout": {
    "patch": {
      "summary": "Logout user",
      "tags": ["SuperAdmin"],
      "description": "Clears authentication tokens or sessions.",
      "responses": {
        "200": {
          "description": "User logged out successfully"
        }
      }
    }
},

"/admin/refresh": {
    "post": {
      "summary": "Refresh access token",
      "tags": ["SuperAdmin"],
      "description": "Generates a new access token using a valid refresh token.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "refreshToken": { "type": "string" }
              },
              "required": ["refreshToken"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "New access token issued"
        },
        "403": {
          "description": "Invalid or expired refresh token"
        }
      }
    }
},

"/admin/password/request-token": {
    "post": {
      "summary": "Request password reset",
      "tags": ["SuperAdmin"],
      "description": "Sends a password reset link/token to the user's email.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "email": { "type": "string", "format": "email" }
              },
              "required": ["email"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Password reset instructions sent"
        },
        "404": {
          "description": "Email not found"
        }
      }
    }
},

"/admin/reset-password/{token}": {
    "post": {
      "summary": "Reset password",
      "tags": ["SuperAdmin"],
      "description": "Allows user to reset password using a valid token.",
      "parameters": [
        {
          "name": "token",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Reset token sent to the user's email"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "newPassword": { "type": "string", "format": "password" }
              },
              "required": ["newPassword"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Password successfully reset"
        },
        "400": {
          "description": "Invalid or expired token"
        }
      }
    }
},

"/admin/modules": {
    "get": {
      "tags": ["SuperAdmin"],
      "summary": "Get all modules",
      "description": "Fetch all modules available for SuperAdmin",
      "operationId": "getAllModules",
      "responses": {
        "200": {
          "description": "Modules fetched successfully",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "statusCode": {
                    "type": "integer",
                    "example": 200
                  },
                  "data": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Module"
                    }
                  },
                  "message": {
                    "type": "string",
                    "example": "Modules fetched successfully"
                  }
                }
              }
            }
          }
        },
        "404": {
          "description": "Modules not found"
        }
      }
    }
},



"/module": {
    "get": {
      "tags": ["Module"],
      "summary": "Get all modules",
      "description": "Fetch all modules",
      "responses": {
        "200": {
          "description": "Modules fetched successfully"
        },
        "404": {
          "description": "Modules not found"
        }
      }
    },
    "post": {
      "tags": ["Module"],
      "summary": "Create a module",
      "description": "Creates a new module",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "price": { "type": "number" },
                "description": { "type": "string" }
              },
              "required": ["name", "description"]
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Module created successfully"
        },
        "400": {
          "description": "Module already exists"
        },
        "500": {
          "description": "Server error"
        }
      }
    }
},

"/module/{id}": {
    "patch": {
      "tags": ["Module"],
      "summary": "Update a module",
      "description": "Updates the details of an existing module",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "ID of the module to update"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "price": { "type": "number" },
                "description": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Module updated successfully"
        },
        "400": {
          "description": "Module already exists"
        },
        "404": {
          "description": "Module not found"
        }
      }
    },
    "delete": {
      "tags": ["Module"],
      "summary": "Delete a module",
      "description": "Deletes a module by ID",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "ID of the module to delete"
        }
      ],
      "responses": {
        "200": {
          "description": "Module deleted successfully"
        },
        "404": {
          "description": "Module not found"
        }
      }
    }
},


"/plan": {
    "post": {
      "tags": ["Plan"],
      "summary": "Create a plan",
      "description": "Creates a new plan with associated modules",
      "requestBody": {
        "required": true,
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "code": { "type": "string" },
                "category": { "type": "string" },
                "status": { "type": "string" },
                "description": { "type": "string" },
                "actualPrice": { "type": "number" },
                "offerPrice": { "type": "number" },
                "billingCycle": { "type": "string" },
                "gst": { "type": "number" },
                "maxStudent": { "type": "number" },
                "maxStaffUser": { "type": "number" },
                "storageLimit": { "type": "number" },
                "minStudentLimit": { "type": "number" },
                "maxStudentLimit": { "type": "number" },
                "perStudentPrice": { "type": "number" },
                "creditCarryForward": { "type": "boolean" },
                "emailNotification": { "type": "boolean" },
                "smsAlerts": { "type": "boolean" },
                "whatsappAlerts": { "type": "boolean" },
                "customeLogoBranding": { "type": "boolean" },
                "icon": { "type": "string", "format": "binary" },
                "iconColor": { "type": "string" },
                "planPros": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "planCons": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "duration": { "type": "integer" },
                "termsAndPolicy": { "type": "string" },
                "adminNotes": { "type": "string" },
                "modules": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "required": [
                "name",
                "code",
                "category",
                "status",
                "actualPrice",
                "billingCycle",
                "duration"
              ]
            }
          }
        }
      },
      "responses": {
        "201": { "description": "Plan created successfully" },
        "400": { "description": "Plan with same name or code already exists or invalid module IDs" },
        "500": { "description": "Server error" }
      }
    },
    "get": {
      "tags": ["Plan"],
      "summary": "Get all plans",
      "description": "Fetch all plans with their modules",
      "responses": {
        "200": { "description": "Plans fetched successfully" },
        "500": { "description": "Server error" }
      }
    }
},

"/plan/{id}": {
    "get": {
      "tags": ["Plan"],
      "summary": "Get a plan by ID",
      "description": "Fetch a single plan with its modules by ID",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "ID of the plan to fetch"
        }
      ],
      "responses": {
        "200": { "description": "Plan fetched successfully" },
        "404": { "description": "Plan not found" },
        "500": { "description": "Server error" }
      }
    },
    "patch": {
      "tags": ["Plan"],
      "summary": "Update a plan",
      "description": "Updates a plan's details and associated modules",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "ID of the plan to update"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "code": { "type": "string" },
                "category": { "type": "string" },
                "status": { "type": "string" },
                "description": { "type": "string" },
                "price": { "type": "number" },
                "billingCycle": { "type": "string" },
                "gst": { "type": "number" },
                "maxStudent": { "type": "number" },
                "maxStaffUser": { "type": "number" },
                "storageLimit": { "type": "number" },
                "minStudentLimit": { "type": "number" },
                "maxStudentLimit": { "type": "number" },
                "perStudentPrice": { "type": "number" },
                "creditCarryForward": { "type": "boolean" },
                "emailNotification": { "type": "boolean" },
                "smsAlerts": { "type": "boolean" },
                "whatsappAlerts": { "type": "boolean" },
                "customeLogoBranding": { "type": "boolean" },
                "icon": { "type": "string", "format": "binary" },
                "iconColor": { "type": "string" },
                "planPros": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "planCons": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "duration": { "type": "integer" },
                "termsAndPolicy": { "type": "string" },
                "adminNotes": { "type": "string" },
                "modules": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "description": "Plan updated successfully" },
        "400": { "description": "Another plan with same name/code exists or invalid module IDs" },
        "404": { "description": "Plan not found" },
        "500": { "description": "Server error" }
      }
    },
    "delete": {
      "tags": ["Plan"],
      "summary": "Delete a plan",
      "description": "Deletes a plan by ID and its module associations",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "ID of the plan to delete"
        }
      ],
      "responses": {
        "200": { "description": "Plan deleted successfully" },
        "404": { "description": "Plan not found" },
        "500": { "description": "Server error" }
      }
    }
},


"/school/admin/login": {
    "post": {
      "tags": ["School"],
      "summary": "Login as School Admin",
      "description": "Authenticate school admin using email and password",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["email", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "example": "admin@school.com"
                },
                "password": {
                  "type": "string",
                  "example": "securepassword123"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "School admin logged in successfully",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "statusCode": {
                    "type": "integer",
                    "example": 200
                  },
                  "data": {
                    "type": "object",
                    "properties": {
                      "user": {
                        "$ref": "#/components/schemas/User"
                      },
                      "accessToken": {
                        "type": "string",
                        "example": "access.token.value"
                      },
                      "refreshToken": {
                        "type": "string",
                        "example": "refresh.token.value"
                      }
                    }
                  },
                  "message": {
                    "type": "string",
                    "example": "School admin logged in successfully"
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Email and password are required"
        },
        "401": {
          "description": "Invalid credentials"
        },
        "404": {
          "description": "Admin's email or role not found"
        }
      }
    }
},

"/school": {
    "post": {
      "tags": ["School"],
      "summary": "Create a new school",
      "description": "Creates a new school along with a school admin and user. Also creates a dedicated database schema for the school.",
      "requestBody": {
        "required": true,
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "required": [
                "slug", "institutionName", "institutionType", "board", "establishmentYear",
                "medium", "totalStudent", "contactPersonName", "contactNumber", "alternateNumber",
                "addressLine1", "addressLine2", "email", "city", "state", "pincode", "country",
                "plan", "smsSenderId", "whatsappNumber", "adminName", "adminEmail",
                "adminMobileNumber", "notes", "password"
              ],
              "properties": {
                "slug": { 
                  "type": "string",
                  "example": "greenwood_high_school",
                  "description": "Unique identifier for the school (used for database schema)"
                },
                "institutionName": { 
                  "type": "string",
                  "example": "Greenwood High School"
                },
                "institutionType": { 
                  "type": "string",
                  "example": "School"
                },
                "board": { 
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["CBSE", "ICSE", "State-Board", "IB"]
                  },
