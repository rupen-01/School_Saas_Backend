    "put": {
      "tags": ["Class Master"],
      "summary": "Update class master",
      "description": "Updates an existing class master",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
