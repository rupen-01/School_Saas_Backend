  "/settings/academic-year": {
    "post": {
      "tags": ["Academic Year Settings"],
      "summary": "Create a new academic year",
      "description": "Creates a new academic year. If is_active is set to true, all other academic years will be deactivated.",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "academic_year_label": {
                  "type": "string",
                  "example": "2024-2025"
                },
                "start_date": {
                  "type": "string",
                  "format": "date",
                  "example": "2024-04-01"
                },
                "end_date": {
                  "type": "string",
                  "format": "date",
                  "example": "2025-03-31"
                },
                "description": {
                  "type": "string",
                  "example": "Academic year 2024-2025"
                },
                "is_active": {
                  "type": "boolean",
                  "example": false
                }
              },
              "required": ["academic_year_label", "start_date", "end_date"]
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Academic year created successfully"
        },
        "400": {
          "description": "Bad request - validation error"
        }
      }
    },
    "get": {
      "tags": ["Academic Year Settings"],
      "summary": "Get all academic years",
      "description": "Retrieves all academic years with optional filtering",
      "parameters": [
        {
          "name": "include_deleted",
          "in": "query",
          "required": false,
          "schema": {
            "type": "boolean",
            "default": false
          }
        },
        {
          "name": "is_active",
          "in": "query",
          "required": false,
          "schema": {
            "type": "boolean"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Academic years fetched successfully"
        }
      }
    }
  },

  "/settings/academic-year/active": {
    "get": {
      "tags": ["Academic Year Settings"],
