          "application/json": {
            "schema": {
              "type": "object",
              "required": ["class_name"],
              "properties": {
                "class_name": {
                  "type": "string",
                  "example": "1st"
                },
                "class_code": {
                  "type": "string",
                  "example": "C1"
                },
                "display_order": {
                  "type": "integer",
                  "example": 1
                },
                "description": {
                  "type": "string",
                  "example": "First grade class"
                },
                "is_active": {
                  "type": "boolean",
                  "example": true
                }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Class master created successfully"
        },
        "400": {
          "description": "Class name is required or class already exists"
        }
      }
    },
    "get": {
      "tags": ["Class Master"],
      "summary": "Get all class masters",
      "description": "Retrieves all class master entries",
      "parameters": [
        {
          "name": "include_deleted",
          "in": "query",
          "schema": {
            "type": "boolean",
            "default": false
          }
        },
        {
          "name": "is_active",
          "in": "query",
          "schema": {
            "type": "boolean"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Class masters fetched successfully"
        }
      }
    }
  },

