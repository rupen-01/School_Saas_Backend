      }
    },
    "schemas": {
      "ClassMaster": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the class master"
          },
          "class_name": {
            "type": "string",
            "description": "Name of the class (e.g., 1st, 2nd, Pre-K)"
          },
          "class_code": {
            "type": "string",
            "description": "Optional code for the class (e.g., C1, C2)"
          },
          "display_order": {
            "type": "integer",
            "description": "Order for displaying classes"
          },
          "description": {
            "type": "string",
            "description": "Optional description of the class"
          },
          "is_active": {
            "type": "boolean",
            "description": "Whether the class is active"
          },
          "created_by": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the user who created this record"
          },
          "updated_by": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the user who last updated this record"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
