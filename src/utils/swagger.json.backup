                },
                "description": {
                  "type": "string",
                  "example": "Standard medical leave policy"
                },
                "leave_type_id": {
                  "type": "string",
                  "example": "uuid"
                },
                "department_id": {
                  "type": "string",
                  "example": "uuid"
                },
                "max_days_per_year": {
                  "type": "integer",
                  "example": 15
                },
                "auto_approve": {
                  "type": "boolean",
                  "example": true
                },
                "approval_required": {
                  "type": "boolean",
                  "example": false
                },
                "status": {
                  "type": "boolean",
                  "example": true
                }
              },
              "required": ["name", "leave_type_id", "max_days_per_year"]
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Leave policy created successfully"
        },
        "400": {
